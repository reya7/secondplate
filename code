<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SecondPlate - Fight Food Waste</title>
    <!-- Tailwind CSS via CDN (No install needed!) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        /* Smooth scroll for the anchor links */
        html { scroll-behavior: smooth; }
        .hover-scale { transition: transform 0.2s; }
        .hover-scale:hover { transform: scale(1.05); }
    </style>
</head>
<body>

    <!-- ========== HEADER ========== -->
    <header class="bg-white shadow-md py-4 px-6 md:px-12 flex justify-between items-center sticky top-0 z-50">
        <a href="#" class="text-2xl font-bold text-green-700 flex items-center gap-2">
            <i class="fas fa-utensils"></i> SecondPlate
        </a>
        <nav class="space-x-4 md:space-x-6 text-gray-700">
            <a href="#how-it-works" class="hover:text-green-600 font-medium">How It Works</a>
            <a href="#features" class="hover:text-green-600 font-medium hidden md:inline">Features</a>
            <a href="#impact" class="hover:text-green-600 font-medium hidden md:inline">Impact</a>
            <a href="#cta" class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 font-semibold text-sm">
                <i class="fas fa-user-plus mr-1"></i> Sign Up
            </a>
        </nav>
    </header>

    <main>
        <!-- ========== HERO SECTION ========== -->
        <section class="bg-gradient-to-br from-green-50 to-white py-20 px-6 text-center">
            <div class="max-w-4xl mx-auto">
                <h1 class="text-4xl md:text-6xl font-extrabold text-green-800 leading-tight">
                    Turn Surplus Food <br />Into <span class="text-green-600">Community Impact</span>
                </h1>
                <p class="text-lg md:text-xl text-gray-600 mt-4 max-w-2xl mx-auto">
                    SecondPlate connects restaurants with surplus food to local NGOs and volunteers. 
                    Together, we rescue meals, reduce waste, and feed communities.
                </p>
                <div class="mt-8 flex flex-wrap justify-center gap-4">
                    <a href="#cta" class="bg-green-600 text-white px-8 py-3 rounded-lg font-bold hover:bg-green-700 shadow-lg hover-scale">
                        <i class="fas fa-hand-holding-heart mr-2"></i> Join the Movement
                    </a>
                    <a href="#how-it-works" class="bg-white text-green-600 border-2 border-green-600 px-8 py-3 rounded-lg font-bold hover:bg-green-50 hover-scale">
                        <i class="fas fa-play-circle mr-2"></i> See How It Works
                    </a>
                </div>
            </div>
        </section>

        <!-- ========== STATS SECTION ========== -->
        <section id="impact" class="py-16 px-6 bg-white max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center border-b-2 border-gray-100">
            <div>
                <div class="text-4xl md:text-5xl font-black text-green-700">2,400<span class="text-2xl">+</span></div>
                <div class="text-gray-600 font-medium">Meals Saved</div>
            </div>
            <div>
                <div class="text-4xl md:text-5xl font-black text-green-700">1,200<span class="text-2xl">kg</span></div>
                <div class="text-gray-600 font-medium">CO₂ Saved</div>
            </div>
            <div>
                <div class="text-4xl md:text-5xl font-black text-green-700">45<span class="text-2xl">+</span></div>
                <div class="text-gray-600 font-medium">Restaurants</div>
            </div>
            <div>
                <div class="text-4xl md:text-5xl font-black text-green-700">12<span class="text-2xl">+</span></div>
                <div class="text-gray-600 font-medium">NGOs Partnered</div>
            </div>
        </section>

        <!-- ========== HOW IT WORKS ========== -->
        <section id="how-it-works" class="py-20 px-6 bg-gray-50">
            <h2 class="text-3xl md:text-4xl font-bold text-center text-gray-800">From Surplus to <span class="text-green-600">Supper</span></h2>
            <p class="text-center text-gray-500 mt-2">A simple four-step process that turns food waste into community impact.</p>
            <div class="max-w-6xl mx-auto grid md:grid-cols-4 gap-6 mt-12">
                <div class="bg-white p-6 rounded-2xl shadow-md text-center border-t-4 border-green-500">
                    <div class="bg-green-100 w-14 h-14 rounded-full flex items-center justify-center text-2xl font-black text-green-700 mx-auto">1</div>
                    <h3 class="text-xl font-bold mt-4">List Surplus Food</h3>
                    <p class="text-gray-600 text-sm mt-1">Restaurants log excess food with details on quantity, type, and pickup window.</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-md text-center border-t-4 border-blue-500">
                    <div class="bg-blue-100 w-14 h-14 rounded-full flex items-center justify-center text-2xl font-black text-blue-700 mx-auto">2</div>
                    <h3 class="text-xl font-bold mt-4">NGO Claims</h3>
                    <p class="text-gray-600 text-sm mt-1">NGOs browse available food and claim what they need with AI matching.</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-md text-center border-t-4 border-purple-500">
                    <div class="bg-purple-100 w-14 h-14 rounded-full flex items-center justify-center text-2xl font-black text-purple-700 mx-auto">3</div>
                    <h3 class="text-xl font-bold mt-4">Volunteers Deliver</h3>
                    <p class="text-gray-600 text-sm mt-1">Volunteers pick up and deliver food to NGOs, tracked in real-time.</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-md text-center border-t-4 border-orange-500">
                    <div class="bg-orange-100 w-14 h-14 rounded-full flex items-center justify-center text-2xl font-black text-orange-700 mx-auto">4</div>
                    <h3 class="text-xl font-bold mt-4">Track Impact</h3>
                    <p class="text-gray-600 text-sm mt-1">Every meal saved, kg of CO₂ prevented, and person fed is celebrated.</p>
                </div>
            </div>
        </section>

        <!-- ========== FEATURES ========== -->
        <section id="features" class="py-20 px-6 max-w-6xl mx-auto">
            <h2 class="text-3xl md:text-4xl font-bold text-center text-gray-800">Built for <span class="text-green-600">Impact</span></h2>
            <p class="text-center text-gray-500 mt-2">Everything you need to manage food donations seamlessly.</p>
            <div class="grid md:grid-cols-3 gap-8 mt-12">
                <div class="p-6 rounded-xl border hover:shadow-xl transition-shadow text-center">
                    <i class="fas fa-robot text-4xl text-green-600 mb-4"></i>
                    <h3 class="text-xl font-bold">AI-Powered Classification</h3>
                    <p class="text-gray-600 text-sm mt-2">Auto-categorize food items, estimate servings, and detect freshness.</p>
                </div>
                <div class="p-6 rounded-xl border hover:shadow-xl transition-shadow text-center">
                    <i class="fas fa-map-pin text-4xl text-blue-600 mb-4"></i>
                    <h3 class="text-xl font-bold">Real-Time Matching</h3>
                    <p class="text-gray-600 text-sm mt-2">Smart algorithm matches surplus food with nearby NGOs for fastest distribution.</p>
                </div>
                <div class="p-6 rounded-xl border hover:shadow-xl transition-shadow text-center">
                    <i class="fas fa-shield-alt text-4xl text-purple-600 mb-4"></i>
                    <h3 class="text-xl font-bold">Fraud Detection</h3>
                    <p class="text-gray-600 text-sm mt-2">AI monitors listings for suspicious activity to ensure platform integrity.</p>
                </div>
                <div class="p-6 rounded-xl border hover:shadow-xl transition-shadow text-center">
                    <i class="fas fa-trophy text-4xl text-yellow-500 mb-4"></i>
                    <h3 class="text-xl font-bold">Gamification & Badges</h3>
                    <p class="text-gray-600 text-sm mt-2">Earn achievements, climb leaderboards, and get recognized for your impact.</p>
                </div>
                <div class="p-6 rounded-xl border hover:shadow-xl transition-shadow text-center">
                    <i class="fas fa-chart-line text-4xl text-indigo-600 mb-4"></i>
                    <h3 class="text-xl font-bold">Impact Analytics</h3>
                    <p class="text-gray-600 text-sm mt-2">Detailed dashboards showing meals saved, CO2 prevented, and community growth.</p>
                </div>
                <div class="p-6 rounded-xl border hover:shadow-xl transition-shadow text-center">
                    <i class="fas fa-camera text-4xl text-red-500 mb-4"></i>
                    <h3 class="text-xl font-bold">Verification System</h3>
                    <p class="text-gray-600 text-sm mt-2">Photo verification, ratings, and delivery confirmation for accountability.</p>
                </div>
            </div>
        </section>

        <!-- ========== CALL TO ACTION ========== -->
        <section id="cta" class="bg-green-700 text-white py-20 px-6 text-center">
            <div class="max-w-2xl mx-auto">
                <h2 class="text-3xl md:text-4xl font-bold">Ready to Fight <span class="text-green-200">Food Waste</span>?</h2>
                <p class="text-lg opacity-90 mt-4">Join hundreds of restaurants, NGOs, and volunteers making a difference. Sign up in under 2 minutes.</p>
                <div class="mt-8 flex flex-wrap justify-center gap-4">
                    <a href="#" class="bg-white text-green-700 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 shadow-lg hover-scale">
                        <i class="fas fa-rocket mr-2"></i> Get Started Free
                    </a>
                    <a href="#" class="bg-transparent border-2 border-white px-8 py-3 rounded-lg font-bold hover:bg-green-600 hover-scale">
                        Learn More
                    </a>
                </div>
            </div>
        </section>
    </main>

    <!-- ========== FOOTER ========== -->
    <footer class="bg-gray-900 text-gray-400 py-8 px-6 text-center border-t border-gray-800">
        <div class="flex flex-col md:flex-row justify-between items-center max-w-6xl mx-auto">
            <p class="text-sm">© 2026 <span class="text-white font-semibold">SecondPlate</span>. Fighting food waste together.</p>
            <div class="flex space-x-6 mt-4 md:mt-0">
                <a href="#" class="hover:text-white text-sm">Privacy</a>
                <a href="#" class="hover:text-white text-sm">Terms</a>
                <a href="#" class="hover:text-white text-sm">Contact</a>
                <a href="#" class="hover:text-white"><i class="fab fa-twitter"></i></a>
                <a href="#" class="hover:text-white"><i class="fab fa-linkedin"></i></a>
            </div>
        </div>
    </footer>

</body>
</html>
